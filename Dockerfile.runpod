# Mycelium Pipeline — All-in-one RunPod image
# Contains: NATS server, vLLM, Node.js pipeline + frontend
# Usage: Build and push to Docker Hub, then use as RunPod template

FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# System deps
RUN apt-get update && apt-get install -y \
    curl wget git build-essential \
    python3 python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs

# Install NATS server
RUN curl -L https://github.com/nats-io/nats-server/releases/download/v2.10.24/nats-server-v2.10.24-linux-amd64.tar.gz | tar xz \
    && mv nats-server-v2.10.24-linux-amd64/nats-server /usr/local/bin/ \
    && rm -rf nats-server-v2.10.24-linux-amd64

# Install vLLM
RUN pip install --no-cache-dir vllm

# Create app directory
WORKDIR /app

# Build pipeline
COPY package*.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src/ ./src/
RUN npm run build

# Build frontend
COPY frontend/package*.json ./frontend/
RUN cd frontend && npm ci
COPY frontend/ ./frontend/
RUN cd frontend && npm run build

# Copy runtime files
COPY prompts/ ./prompts/

# Create data directories
RUN mkdir -p /data/nats /data/muninndb /data/pipeline

# Copy startup script
COPY start.sh /app/start.sh
RUN chmod +x /app/start.sh

EXPOSE 3001 4222 8000

CMD ["/app/start.sh"]
